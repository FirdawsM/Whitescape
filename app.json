{
  "expo": {
    "name": "Whitescape",
    "slug": "whitescape",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "whitescape",
    "icon": "./assets/App Icon — 1024x1024.png",
    "splash": {
      "image": "./assets/Splash Screen — 1080x1920.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A0A0F"
    },
    "userInterfaceStyle": "dark",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "name": "Whitescape - Find your frequency",
      "description": "Find your frequency with Whitescape. Premium soundscapes for relaxing, studying, walking, focusing, or hanging out.",
      "meta": {
        "og:title": "Whitescape",
        "og:description": "Find your frequency with Whitescape.",
        "og:type": "website"
      }
    },
    "android": {
      "package": "com.whitescape.app",
      "googleServicesFile": "./google-services.json"
    },
    "ios": {
      "bundleIdentifier": "com.whitescape.app",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6752133303883908~4481231714",
          "iosAppId": "ca-app-pub-6752133303883908~4481231714"
        }
      ],
      "@react-native-firebase/app",
      [
        "@react-native-firebase/analytics",
        {
          "ios": {
            "withoutAdIdSupport": true
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "extraProguardRules": "-keep public class com.google.android.gms.ads.** { public *; }\n-keep public class com.google.ads.** { public *; }",
            "packagingOptions": {
              "pickFirst": ["**/libc++_shared.so"]
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c7860a3c-7a0a-49fc-a8c9-63f9fcbc93b8"
      }
    }
  }
}
